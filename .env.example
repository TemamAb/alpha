# Production Environment Variables for AlphaMark Arb Bot
# Copy to .env and fill real values. Render manages production .env

# Core
PRIVATE_KEY=0x_your_wallet_private_key_do_not_share_
WALLET_ADDRESS=0x_your_wallet_address
DEPLOYER_ADDRESS=0x_deployer_address

# RPCs - Production Mainnet
POLYGON_RPC_URL=https://polygon-rpc.com/your-key  # or Alchemy/Infura
# Add other chains as needed: ETH_RPC_URL=..., ARBITRUM_RPC_URL=...

# Pimlico Gasless - Get API key from https://pimlico.io/dashboard
PIMLICO_API_KEY=pk_your_pimlico_project_key_here

# Contract - Update after mainnet deploy
FLASHLOAN_CONTRACT_ADDRESS=0xYourDeployedFlashLoanArbitrage_Mainnet

# Dashboard/AI
OPENAI_API_KEY=sk-your-openai-key
PAPER_TRADING_MODE=false  # Set true for simulation only!

# Redis (Render auto-provides)
# REDIS_URL=...

# 1inch API key optional for higher rates
# ONE_INCH_API_KEY=your-key

