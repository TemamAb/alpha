# AlphaMark Environment Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!

# ===================
# WALLET CONFIGURATION
# ===================
# Your wallet address for transactions
WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Your private key (DO NOT COMMIT THIS!)
PRIVATE_KEY=your_private_key_here

# ===================
# RPC CONFIGURATION
# ===================
# Ethereum Mainnet
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Polygon
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
POLYGON_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Arbitrum
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ARBITRUM_WS_URL=wss://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ===================
# PIMLICO (GASLESS)
# ===================
# Get your API key from https://dashboard.pimlico.io
PIMLICO_API_KEY=your_pimlico_api_key
ETHEREUM_RPC=https://api.pimlico.io/v1/1/rpc?apikey=your_pimlico_api_key

# ===================
# TRADING MODE
# ===================
# Set to "true" for paper trading (simulation only)
# Set to "false" for live trading with real funds
PAPER_TRADING_MODE=false

# ===================
# REDIS (OPTIONAL)
# ===================
# Redis URL for mode sync with dashboard (optional for local dev)
# REDIS_URL=redis://localhost:6379

# ===================
# OPTIONAL: AI COPILOT
# ===================
# For Alpha-Copilot AI assistant
# OPENAI_API_KEY=your_openai_api_key
