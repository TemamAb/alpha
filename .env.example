# AlphaMark Environment Variables Example
# Copy to .env and fill values

# Trading Mode (MANDATORY: true for testing)
PAPER_TRADING_MODE=true

# Wallet (use Hardhat test account for local: 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80)
PRIVATE_KEY=your_wallet_private_key_here
WALLET_ADDRESS=your_wallet_address_here

# RPC Endpoints (Local for Phase 1)
ETHEREUM_RPC=http://127.0.0.1:8545
ETHEREUM_WS=ws://127.0.0.1:8546
POLYGON_RPC=http://127.0.0.1:8547
POLYGON_WS=ws://127.0.0.1:8548
BSC_RPC=http://127.0.0.1:8549
BSC_WS=ws://127.0.0.1:8550

# Redis (Docker)
REDIS_URL=redis://localhost:6379

# API Keys (Optional)
OPENAI_API_KEY=your_openai_key
PIMLICO_API_KEY=your_pimlico_key  # Gasless AA

# Thresholds
MIN_PROFIT_USD=10.0
MAX_SLIPPAGE_PCT=0.5
MAX_GAS_USD=5.0

# Chains Enabled
ENABLE_ETHEREUM=true
ENABLE_POLYGON=true
ENABLE_BSC=true
