{
  "compilerOptions": {
    "lib": ["es2020"],
    "moduleResolution": "node",
    "target": "es2020",
    "module": "es2020",
    "strict": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "typeRoots": [ "./node_modules/@types" ],
    "types": [ "node" ]
  },
  "include": [
    "./scripts",
    "./test",
    "./hardhat.config.ts"
  ],
  "files": ["./hardhat.config.ts"]
}

