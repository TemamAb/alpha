# AlphaMark Production Environment Template
# ⚠️ NEVER commit your .env file! Use secrets managers for production.
# Copy to .env and fill in your values.

# 🔑 Wallet & Keys (CRITICAL)
PRIVATE_KEY=0x_your_wallet_private_key_here
PIMLICO_API_KEY=pk_your_pimlico_project_key_here  # https://pimlico.io
DEPLOYER_ADDRESS=0x_your_deployer_wallet_here
FLASHLOAN_CONTRACT_ADDRESS=0x_deployed_flashloan_contract_here

# 🌐 RPC Endpoints (Alchemy/Infura - get free tier)
ETHEREUM_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ETHEREUM_RPC_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY  # Testnet first!
POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# ⚙️ Trading Mode (SAFETY FIRST)
PAPER_TRADING_MODE=true  # Set to 'false' ONLY after testnet success
MAX_SLIPPAGE=0.005
MIN_USD_PROFIT=50

# 📊 Dashboard & Redis
REDIS_URL=redis://redis:6379
DASHBOARD_URL=http://localhost:3000
OPENAI_API_KEY=sk-your-openai-key  # Optional: Alpha-Copilot

# 🚀 Fly.io Production (Optional)
FLY_API_TOKEN=your_fly_token_here

# Kill Switch (Emergency)
KILL_SWITCH=false

# Production: Enable MEV Protection
MEV_PROTECTION=true

## DEPLOYMENT CHECKLIST:
# [ ] 1. Fill keys above
# [ ] 2. Deploy FlashLoan.sol → Testnet → Copy address to FLASHLOAN_CONTRACT_ADDRESS
# [ ] 3. docker-compose up → Verify dashboard
# [ ] 4. Test paper trading 1h → All green?
# [ ] 5. fly deploy → Monitor logs
# [ ] 6. Set PAPER_TRADING_MODE=false → LIVE TRADING!

# 🚨 WARNING: LIVE TRADING = REAL MONEY RISK. Testnet first!

