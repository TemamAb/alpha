FROM python:3.11-slim

WORKDIR /app

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    curl \
    redis-tools \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies into the runtime image so the non-root bot user can import them.
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

# Set Python path
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PIP_NO_CACHE_DIR=1

# Safe default for deployment-plan execution.
# Phase 3 explicitly overrides this to false for live trading.
ENV PAPER_TRADING_MODE=true

# Create non-root user for security
RUN useradd -m -u 1000 botuser && chown -R botuser:botuser /app
USER botuser

# Health check using Python (more reliable than redis-cli, avoids shell expansion issues)
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD python -c "import redis, os; r = redis.from_url(os.environ.get('REDIS_URL', ''), socket_timeout=5); r.ping()" || exit 1

# Run the bot - starts in PAPER TRADING MODE by default (safe)
CMD ["python", "execution_bot/scripts/bot.py"]
