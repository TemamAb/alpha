{
  "version": 2,
  "builds": [
    {
      "src": "flashloan_app/monitoring_dashboard/server-dashboard.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["flashloan_app/monitoring_dashboard/frontend/**"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "flashloan_app/monitoring_dashboard/server-dashboard.js" }
  ]
}